# ──────────────────────────────────────────────────────────────────────────
# StemConnect — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# Database (MongoDB Atlas or local) — PRD §12
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/stemconnect?retryWrites=true&w=majority"

# Auth.js / NextAuth — Stage 2
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (credentials + Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email — Resend (verification, password reset, lead + review notifications)
RESEND_API_KEY=""
EMAIL_FROM="StemConnect <no-reply@stemconnect.example>"

# Media provider — Cloudinary (or swap for UploadThing/S3 in lib/media.ts)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Maps (clinic location maps + geocode helper)
NEXT_PUBLIC_MAPS_API_KEY=""

# Rate limiting — Upstash Redis (public forms: review, lead, contact)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Captcha — hCaptcha or Cloudflare Turnstile
CAPTCHA_PROVIDER="turnstile"          # "turnstile" (default) or "hcaptcha"
NEXT_PUBLIC_CAPTCHA_SITE_KEY=""
CAPTCHA_SECRET_KEY=""

# Analytics (optional — primarily configured in admin Settings → analytics).
# These env vars are build-time fallbacks if Settings are unset.
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Vercel Cron — shared secret for /api/cron/* (Stage 9.1).
# Generate: `openssl rand -base64 32`. Required in production; optional in dev.
CRON_SECRET=""

# Public site URL (canonical/OG/sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────
# SEO team dashboard (/seoteam → publishes to public /blog)
# ──────────────────────────────────────────────────────────────────────────
# Single shared password the SEO team uses to sign in at /seoteam.
SEO_DASHBOARD_PASSWORD=""
# Secret used to sign the dashboard session cookie (HMAC-SHA256).
# Generate: `openssl rand -base64 32`
SESSION_SECRET=""
# Inline blog images + cover uploads reuse the Cloudinary vars above
# (CLOUDINARY_*). If those are unset, the editor falls back to pasting image URLs.
